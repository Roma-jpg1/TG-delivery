SERVICE_NAME=tg-delivery
APP_ENV=local
LOG_LEVEL=info
APP_ROLE=api

HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s

DATABASE_URL=postgres://postgres:postgres@postgres:5432/tg_delivery?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=2
DB_MAX_CONN_IDLE_TIME=5m
DB_HEALTHCHECK_TIMEOUT=2s

WORKER_OUTBOX_POLL_INTERVAL=2s
WORKER_BATCH_SIZE=100

ADMIN_TOKEN=dev-admin-token
MOCK_PAYMENT_WEBHOOK_SECRET=dev-mock-payment-secret
TELEGRAM_WEBHOOK_SECRET=dev-telegram-secret
